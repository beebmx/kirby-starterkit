{
    "name": "beebmx/kirby-starterkit",
    "type": "project",
    "description": "Beeb.mx Starter Kit for Kirby CMS",
    "keywords": ["kirby", "cms", "starterkit"],
    "homepage": "https://getkirby.com",
    "authors": [
        {
            "name": "Bastian Allgeier",
            "email": "bastian@getkirby.com",
            "homepage": "https://getkirby.com"
        }, {
            "name": "Fernando Gutiérrez",
            "homepage": "https://beeb.mx"
        }
    ],
    "support": {
        "email": "support@getkirby.com",
        "issues": "https://github.com/beebmx/kirby-starterkit/issues",
        "source": "https://github.com/beebmx/kirby-starterkit"
    },
    "require": {
        "php": "^8.3",
        "getkirby/cms": "^5.0",
        "beebmx/kirby-blade": "^6.0",
        "beebmx/kirby-courier": "^1.0",
        "beebmx/kirby-enum": "^1.0",
        "beebmx/kirby-env": "^5.0",
        "beebmx/kirby-scheduler": "^1.0",
        "beebmx/kirby-sign": "^1.0"
    },
    "require-dev": {
        "spatie/ray": "^1.0",
        "laravel/pint": "^1.0",
        "pestphp/pest": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "test": [
            "php tests/helpers.php",
            "vendor/bin/pest"
        ],
        "pest-init": [
            "php tests/helpers.php",
            "vendor/bin/pest --init"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "allow-plugins": {
            "getkirby/composer-installer": true,
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "kirby-cms-path": false
    }
}
